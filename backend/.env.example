# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Required for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string

# Optional token lifetime in days (default: 7)
# JWT_EXPIRE_DAYS=7

# Optional: Database path (useful for Vercel/serverless environments, default: backend/data/meetingly.db)
# DATABASE_PATH=/tmp/meetingly.db

# Optional: CORS allowed origins for hosting on platforms like Vercel (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://another-domain.com
